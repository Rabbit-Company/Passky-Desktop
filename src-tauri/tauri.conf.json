{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "passky-desktop",
  "version": "8.1.3",
  "identifier": "com.rabbit-company.passky",
  "build": {
    "beforeDevCommand": "bun run build",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Passky",
        "width": 550,
        "height": 550,
        "minWidth": 550,
        "minHeight": 550,
        "devtools": false,
        "backgroundColor": "#0D1117"
      }
    ],
    "security": {
      "csp": "script-src 'self' 'unsafe-inline' https://storage.googleapis.com/; base-uri 'none'; object-src 'none'; form-action 'self'; frame-ancestors 'none'; worker-src 'self' blob:;",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Permissions-Policy": "interest-cohort=()"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
